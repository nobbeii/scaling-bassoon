import requests

# Substitua pelo seu Token de Acesso
TOKEN = "SEU_TOKEN_AQUI"
headers = {"Authorization": f"token {TOKEN}"}

def checar_seguranca():
    url = "https://api.github.com/user/repos"
    response = requests.get(url, headers=headers)
    
    if response.status_code == 200:
        repos = response.json()
        for repo in repos:
            status = "PRIVADO" if repo['private'] else "PÚBLICO"
            print(f"Repositório: {repo['name']} | Status: {status}")
    else:
        print("Erro ao acessar. Verifique seu token.")

checar_seguranca()
